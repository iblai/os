# ibl.ai Configuration
# Copy this file to .env and customize as needed

# App URL - the URL that the ibl.ai app loads
#
# For development (debug builds):
#   Defaults to http://localhost:3001 if not set
#
# For production (release builds):
#   Defaults to https://mentorai.iblai.app if not set
#
# To override, set the TAURI_APP_URL environment variable:
# TAURI_APP_URL=https://mentorai.iblai.app

# For custom deployments, uncomment and set your URL:
# TAURI_APP_URL=https://your-custom-mentor-url.example.com
