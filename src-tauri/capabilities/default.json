{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Mentor AI app",
  "windows": ["main"],
  "local": true,
  "remote": {
    "urls": [
      "https://*.iblai.app/*",
      "https://*.iblai.org/*",
      "http://127.0.0.1:*/*",
      "http://localhost:*/*",
      "http://localhost:3456",
      "http://localhost:3456/*",
      "mentor://localhost/*"
    ]
  },
  "permissions": [
    "allow-check-ollama-status",
    "allow-download-phi3-model",
    "allow-download-model",
    "allow-ollama-chat",
    "allow-ollama-chat-stream",
    "allow-check-disk-space-for-model",
    "allow-cancel-model-download",
    "allow-install-ollama",
    "allow-stop-ollama",
    "core:webview:allow-internal-toggle-devtools",
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:path:default",
    "core:app:default",
    "core:resources:default",
    "core:window:default",
    "core:window:allow-create",
    "core:window:allow-center",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:window:allow-set-title",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "shell:allow-open",
    "allow-open-external-url",
    "allow-navigate-to",
    "allow-get-os-type",
    "os:default",
    "allow-check-network-status"
  ]
}
