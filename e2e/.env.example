# Mentor App E2E Test Configuration
MENTOR_NEXTJS_HOST=http://localhost:3000
AUTH_HOST=https://auth.iblai.org

# Authentication
PLAYWRIGHT_USERNAME=your-test-user@example.com
PLAYWRIGHT_PASSWORD=your-test-password
AUTH_FLOW=username_password
AUTH_IDP=

# Per-browser credentials (optional - falls back to default above)
# PLAYWRIGHT_USERNAME_CHROME=
# PLAYWRIGHT_PASSWORD_CHROME=
# PLAYWRIGHT_USERNAME_FIREFOX=
# PLAYWRIGHT_PASSWORD_FIREFOX=
# PLAYWRIGHT_USERNAME_SAFARI=
# PLAYWRIGHT_PASSWORD_SAFARI=
# PLAYWRIGHT_USERNAME_EDGE=
# PLAYWRIGHT_PASSWORD_EDGE=

# Optional - for specific test features
MENTOR_NEXTJS_STRIPE_HOST=
DM_URL=
ECOMMERCE_CREDIT_CLEANUP_TOKEN=
EXTERNAL_STRIPE_PRICING_URL=
IBL_MENTOR_DISABLED_TABS=
NEW_MENTOR_NAME=
NEW_MENTOR_DESCRIPTION=
EMBED_URL=https://conradmugabe.vercel.app/
WCAG_RANGE=
ENABLE_STRIPE_TEST=false
FORDHAM_HOST=
INVITE_USERNAME=
INVITE_USER_PASSWORD=
AUTH_NEXTJS_HOST=

# Canvas LMS embed tests (Journey 11)
# Set all three to enable canvas-embed/canvas-embed.spec.ts
CANVAS_URL=
CANVAS_EMAIL=
CANVAS_PASSWORD=

# Tenant key used by the Data Reports download page tests (e.g. "my-org").
# If empty, the suite auto-derives it from the live page URL at runtime.
PLAYWRIGHT_TENANT_KEY=

# Advertising tenant user-login test (Journey 32)
# Blocked by an invalid UUID / session_id bug in new-user onboarding on the
# advertising tenant. Set to "true" only after that backend bug is fixed.
ENABLE_ADVERTISING_LOGIN_TEST=

# Global per-test timeout in milliseconds.
# Defaults: 120000 in CI (CI=true), 60000 locally.
# Per-suite test.setTimeout() calls override this for their own describe block.
TEST_TIMEOUT=60000

# Number of times to retry a failed test.
# Defaults: 2 in CI (CI=true), 1 locally.
TEST_RETRIES=1

# Platform selection for auth setup
PLATFORM=mentor
