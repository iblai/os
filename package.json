  "version": "0.67.12",
  "private": false,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": "25.3.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--no-experimental-webstorage' next dev",
    "build": "next build && ./scripts/post-build.sh",
    "start": "PORT=${PORT:-3000} node server-wrapper.js",
    "lint": "next lint --fix && pnpm typecheck",
    "lint:check": "next lint && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "format-lint": "npm run format && npm run lint",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "release": "release-it",
    "check-types": "tsc --noEmit",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "tauri:build:debug": "pnpm build && cargo tauri build --debug",
    "test:e2e": "mkdir -p playwright/.auth && echo '{\"cookies\":[],\"origins\":[]}' > playwright/.auth/user-chrome.json && echo '{\"cookies\":[],\"origins\":[]}' > playwright/.auth/user-edge.json && echo '{\"cookies\":[],\"origins\":[]}' > playwright/.auth/user-safari.json && echo '{\"cookies\":[],\"origins\":[]}' > playwright/.auth/user-firefox.json && playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config e2e/playwright.config.ts --headed"
  },
